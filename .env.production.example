POSTGRES_USER=operator_prod
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=operator_prod

REDIS_PASSWORD=replace-with-strong-redis-password

ENVIRONMENT=production
DEBUG=false
DEMO_MODE=false
DEMO_SHOW_SMS_CODE=false
DEMO_SHOW_EMAIL_CODE=false
AUTO_SCHEMA_SYNC=false
RELOAD=false
PUBLIC_APP_URL=https://lk.operator.ru
CORS_ORIGINS=["https://lk.operator.ru"]
TRUSTED_HOSTS=["lk.operator.ru","localhost","127.0.0.1"]
CLOUD_FUNCTIONS_MODE=false

DATABASE_BACKEND=postgres

YDB_ENDPOINT=ydb.serverless.yandexcloud.net
YDB_PORT=2135
YDB_DATABASE=/ru-central1/b1-example/etn-example
YDB_PROTOCOL=grpcs
YDB_CREDENTIALS_MODE=metadata
YDB_TABLE_PATH_PREFIX=
YDB_ACCESS_TOKEN=
YDB_SERVICE_ACCOUNT_KEY_FILE=

SECRET_KEY=replace-with-64-char-app-secret
JWT_SECRET_KEY=replace-with-64-char-jwt-secret

BILLING_API_URL=https://billing.operator.ru/api/v2
BILLING_API_KEY=replace-with-real-billing-api-key

YKASSA_SHOP_ID=
YKASSA_SECRET_KEY=
YKASSA_WEBHOOK_SECRET=
YKASSA_RETURN_URL=https://lk.operator.ru/payments/success

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@operator.ru
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=noreply@operator.ru
EMAIL_OTP_LENGTH=6
EMAIL_OTP_TTL_SECONDS=600
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_MAX_SENDS_PER_HOUR=5

SMS_PROVIDER=smsru
SMS_API_URL=https://sms.ru/sms/send
SMS_API_KEY=replace-with-sms-api-key

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_MOCK_MODE=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOC_CHAT_ID=

WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:support@operator.ru

SENTRY_DSN=
GRAFANA_PASSWORD=replace-with-grafana-password
GRAFANA_ROOT_URL=https://monitoring.operator.ru

CELERY_WORKER_CONCURRENCY=4

VITE_API_BASE_URL=/api/v1
VITE_WITH_CREDENTIALS=true
VITE_ENABLE_LEGACY_BUCKET_API_MAPPING=false
