[Unit]
Description=MTN FastAPI Web Application
After=network.target redis.service postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/mtn/app
Environment="PYTHONPATH=/opt/mtn/app"
EnvironmentFile=/opt/mtn/app/.env
ExecStart=/opt/mtn/venv/bin/gunicorn app.main:app -c /opt/mtn/app/gunicorn.conf.py
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
