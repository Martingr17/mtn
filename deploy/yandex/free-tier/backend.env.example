ENVIRONMENT=production
DEBUG=false
DEMO_MODE=false
DEMO_SHOW_SMS_CODE=false

CLOUD_FUNCTIONS_MODE=true
AUTO_SCHEMA_SYNC=true
DATABASE_BACKEND=ydb

PUBLIC_APP_URL=https://replace-with-gateway-domain

YDB_ENDPOINT=ydb.serverless.yandexcloud.net
YDB_PORT=2135
YDB_DATABASE=/ru-central1/b1-example/etn-example
YDB_PROTOCOL=grpcs
YDB_CREDENTIALS_MODE=metadata
YDB_TABLE_PATH_PREFIX=
YDB_ACCESS_TOKEN=
YDB_SERVICE_ACCOUNT_KEY_FILE=

REDIS_HOST=memory
REDIS_PORT=6379

ENABLE_WEBSOCKETS=false
MONITORING_EMBED_SCHEDULER=false
PROMETHEUS_ENABLED=false
UPLOAD_DIR=/tmp/uploads

SECRET_KEY=replace-with-64-char-app-secret
JWT_SECRET_KEY=replace-with-64-char-jwt-secret
BILLING_API_KEY=replace-with-real-billing-api-key

CORS_ORIGINS=["https://replace-with-gateway-domain"]
TRUSTED_HOSTS=["replace-with-gateway-domain","localhost","127.0.0.1"]
