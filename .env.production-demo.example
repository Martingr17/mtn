POSTGRES_USER=operator_demo
POSTGRES_PASSWORD=replace-with-demo-db-password
POSTGRES_DB=operator_demo

REDIS_PASSWORD=replace-with-demo-redis-password

ENVIRONMENT=staging
DEBUG=false
DEMO_MODE=true
DEMO_SHOW_SMS_CODE=true
DEMO_SHOW_EMAIL_CODE=true
AUTO_SCHEMA_SYNC=false
RELOAD=false
PUBLIC_APP_URL=https://<your-domain>
CORS_ORIGINS=["https://<your-domain>"]
TRUSTED_HOSTS=["<your-domain>","localhost","127.0.0.1"]
CLOUD_FUNCTIONS_MODE=false

DATABASE_BACKEND=postgres

YDB_ENDPOINT=ydb.serverless.yandexcloud.net
YDB_PORT=2135
YDB_DATABASE=/ru-central1/b1-example/etn-example
YDB_PROTOCOL=grpcs
YDB_CREDENTIALS_MODE=metadata
YDB_TABLE_PATH_PREFIX=
YDB_ACCESS_TOKEN=
YDB_SERVICE_ACCOUNT_KEY_FILE=

SECRET_KEY=replace-with-64-char-production-demo-app-secret
JWT_SECRET_KEY=replace-with-64-char-production-demo-jwt-secret

BILLING_API_URL=https://operator.local/api/v2
BILLING_API_KEY=production-demo-mock-billing-key

YKASSA_SHOP_ID=
YKASSA_SECRET_KEY=
YKASSA_WEBHOOK_SECRET=
YKASSA_RETURN_URL=https://<your-domain>/payments/success

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.local
EMAIL_OTP_LENGTH=6
EMAIL_OTP_TTL_SECONDS=600
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_MAX_SENDS_PER_HOUR=5

SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_MOCK_MODE=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOC_CHAT_ID=

WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:support@example.local

SENTRY_DSN=
GRAFANA_PASSWORD=replace-with-demo-grafana-password
GRAFANA_ROOT_URL=http://localhost:3000

CELERY_WORKER_CONCURRENCY=2

VITE_API_BASE_URL=/api/v1
VITE_WITH_CREDENTIALS=true
VITE_ENABLE_LEGACY_BUCKET_API_MAPPING=false
