{
  "dashboard": {
    "title": "Operator Platform Monitor",
    "timezone": "browser",
    "panels": [
      {
        "title": "HTTP Requests Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ]
      },
      {
        "title": "Request Duration",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Active Users",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 8},
        "targets": [{"expr": "active_user_count"}]
      },
      {
        "title": "Total Users",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 8},
        "targets": [{"expr": "user_count"}]
      },
      {
        "title": "Revenue Today",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 8},
        "targets": [{"expr": "revenue_today"}],
        "fieldConfig": {"defaults": {"unit": "currencyRUB"}}
      },
      {
        "title": "Open Tickets",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 8},
        "targets": [{"expr": "sum(app_tickets_by_status{status!~\"resolved|closed\"})"}]
      },
      {
        "title": "Tickets by Status",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [{"expr": "app_tickets_by_status"}]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
            "legendFormat": "error rate"
          }
        ]
      }
    ]
  }
}