ENVIRONMENT=development
DEBUG=true
DEMO_MODE=true
DEMO_SHOW_SMS_CODE=true
DEMO_SHOW_EMAIL_CODE=true
AUTO_SCHEMA_SYNC=true
RELOAD=true
PUBLIC_APP_URL=http://localhost:8000
CLOUD_FUNCTIONS_MODE=false

DATABASE_BACKEND=postgres

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=operator
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=operator

YDB_ENDPOINT=ydb.serverless.yandexcloud.net
YDB_PORT=2135
YDB_DATABASE=/ru-central1/b1-example/etn-example
YDB_PROTOCOL=grpcs
YDB_CREDENTIALS_MODE=metadata
YDB_TABLE_PATH_PREFIX=

REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY=supersecretkey12345678901234567890
JWT_SECRET_KEY=jwtsecretkey12345678901234567890
BILLING_API_KEY=12345678901234567890123456789012
EMAIL_OTP_LENGTH=6
EMAIL_OTP_TTL_SECONDS=600
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_MAX_SENDS_PER_HOUR=5
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.local

SMS_PROVIDER=mock
YKASSA_TEST_MODE=true

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOC_CHAT_ID=
TELEGRAM_MOCK_MODE=true
